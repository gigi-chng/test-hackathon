generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model PartnerContent {
  id          String    @id @default(cuid())
  partner     String    // "sam" | "will" | "yoni" | "megan"
  sourceType  String    // "tweet" | "blog" | "newsletter" | "podcast"
  sourceUrl   String?
  title       String?
  content     String
  embedding   Float[]
  tags        String[]  @default([])
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("partner_content")
}

model PartnerProfile {
  id          String    @id @default(cuid())
  partner     String    @unique
  toneOfVoice String    @default("")
  pointOfView String    @default("")
  themes      String[]
  styleNotes  String    @default("")
  rawProfile  String    @default("") // full JSON for agent use
  generatedAt DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@map("partner_profiles")
}

model VideoLibrary {
  id         String   @id @default(cuid())
  partner    String
  title      String
  storageUrl String
  transcript String?
  topics     String[]
  embedding  Float[]
  duration   Int?
  forcedNext Boolean  @default(false)
  uploadedAt DateTime @default(now())

  @@map("video_library")
}

model TrendSignal {
  id             String   @id @default(cuid())
  headline       String
  summary        String
  source         String
  sourceUrl      String?
  relevanceScore Float
  status         String   @default("pending") // pending | drafted | skipped
  detectedAt     DateTime @default(now())

  @@map("trend_signals")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model MediaAppearance {
  id              String    @id @default(cuid())
  partner         String    // "sam" | "will" | "yoni" | "megan"
  type            String    // "podcast" | "press" | "panel" | "newsletter" | "video" | "other"
  show            String
  title           String
  url             String
  publishedAt     DateTime?
  transcript      String?
  topics          String[]
  notes           String?
  status          String    @default("ready") // "processing" | "ready" | "error"
  processingJobId String?
  createdAt       DateTime  @default(now())

  @@map("media_appearances")
}

model TrackerProject {
  id          String          @id @default(cuid())
  vertical    String          // "slow" | "slow-creator" | "sam"
  name        String
  description String?
  status      String          @default("active") // active | paused | completed
  order       Int             @default(0)
  createdAt   DateTime        @default(now())

  kpis        TrackerKPI[]
  weeklyGoals TrackerGoal[]
  updates     TrackerUpdate[]

  @@map("tracker_projects")
}

model TrackerKPI {
  id        String         @id @default(cuid())
  projectId String
  name      String
  unit      String?
  target    Float?
  current   Float?
  stage     String         @default("live") // "pre-live" | "live"
  updatedAt DateTime       @updatedAt
  project   TrackerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tracker_kpis")
}

model TrackerGoal {
  id          String         @id @default(cuid())
  projectId   String
  weekOf      DateTime       // Monday of the week
  text        String
  type        String         @default("deliverable") // "deliverable" | "metric"
  workType    String         @default("sprint")      // "sprint" | "maintenance"
  priority    String         @default("p2")          // "p1" | "p2" | "p3"
  rankOrder   Int            @default(0)
  targetValue Float?
  actualValue Float?
  completed   Boolean        @default(false)
  notes       String?
  createdAt   DateTime       @default(now())
  project     TrackerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tracker_goals")
}

model TrackerUpdate {
  id        String         @id @default(cuid())
  projectId String
  text      String
  createdAt DateTime       @default(now())
  project   TrackerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tracker_updates")
}

model PostDraft {
  id              String    @id @default(cuid())
  trendSignalId   String?
  partner         String
  partnerCitation String
  hook            String
  body            String
  platform        String    @default("both") // twitter | linkedin | both
  videoId         String?
  quoteTweetId    String?
  quoteTweetUrl   String?
  partnerSourceUrl String?
  status          String    @default("pending") // pending | approved | rejected | published
  approvalToken   String    @unique @default(cuid())
  feedback        String?
  source          String    @default("agent") // "agent" | "announcement"
  scheduledAt     DateTime?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@map("post_drafts")
}

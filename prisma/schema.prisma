generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model PartnerContent {
  id          String    @id @default(cuid())
  partner     String    // "sam" | "will" | "yoni" | "megan"
  sourceType  String    // "tweet" | "blog" | "newsletter" | "podcast"
  sourceUrl   String?
  title       String?
  content     String
  embedding   Float[]
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("partner_content")
}

model PartnerProfile {
  id           String   @id @default(cuid())
  partner      String   @unique
  displayName  String
  twitterHandle String?
  topics       String[]
  voiceSamples String[]
  updatedAt    DateTime @updatedAt

  @@map("partner_profiles")
}

model VideoLibrary {
  id         String   @id @default(cuid())
  partner    String
  title      String
  storageUrl String
  transcript String?
  topics     String[]
  embedding  Float[]
  duration   Int?
  uploadedAt DateTime @default(now())

  @@map("video_library")
}

model TrendSignal {
  id             String   @id @default(cuid())
  headline       String
  summary        String
  source         String
  sourceUrl      String?
  relevanceScore Float
  status         String   @default("pending") // pending | drafted | skipped
  detectedAt     DateTime @default(now())

  @@map("trend_signals")
}

model PostDraft {
  id              String    @id @default(cuid())
  trendSignalId   String?
  partner         String
  partnerCitation String
  hook            String
  body            String
  platform        String    @default("both") // twitter | linkedin | both
  videoId         String?
  quoteTweetId    String?
  quoteTweetUrl   String?
  partnerSourceUrl String?
  status          String    @default("pending") // pending | approved | rejected | published
  approvalToken   String    @unique @default(cuid())
  feedback        String?
  source          String    @default("agent") // "agent" | "announcement"
  scheduledAt     DateTime?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@map("post_drafts")
}
